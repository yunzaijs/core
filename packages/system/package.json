{
  "name": "@yunzaijs/system",
  "version": "0.0.1",
  "author": "ningmengchongshui",
  "description": "system",
  "type": "module",
  "scripts": {
    "app": "yunzaijs app",
    "dev": "yunzaijs dev --node-options alemonjs/loader",
    "build": "alemonjs build",
    "server": "npx jsxp dev --node-options alemonjs/loader",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "bundle": "rollup --config rollup.config.js",
    "stop": "pm2 stop pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs",
    "format": "prettier --write .",
    "check-format": "git diff --exit-code",
    "prepare": "husky"
  },
  "dependencies": {
    "jsxp": "^1.0.4",
    "lodash-es": "^4.17.21",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.8.5",
    "@types/node-schedule": "^2.1.7",
    "@types/react": "^18.3.4",
    "alemonjs": "^2.0.0-rc.33",
    "husky": "^9.1.5",
    "icqq": "^0.6.10",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.4.10"
  },
  "types": "lib",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "keywords": [
    "yunzaijs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
